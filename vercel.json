{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/custom", "destination": "/custom.html" },
    { "source": "/artist-goodz", "destination": "/artist-goodz.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/support", "destination": "/support.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy-policy", "destination": "/privacy.html" },
    { "source": "/terms-of-service", "destination": "/terms.html" },
    { "source": "/tapped-add-url", "destination": "/static-pages/tapped-add-url.html" },
    { "source": "/tapped-edit-url", "destination": "/static-pages/tapped-edit-url.html" },
    { "source": "/landing/louisa", "destination": "/static-pages/landing/louisa.html" },
    { "source": "/handles/artopenings-la", "destination": "/static-pages/handles/artopenings-la.html" },
    { "source": "/handles/circle46gallery", "destination": "/static-pages/handles/circle46gallery.html" },
    { "source": "/handles/contemporaryartsociety", "destination": "/static-pages/handles/contemporaryartsociety.html" },
    { "source": "/handles/fernbergergallery", "destination": "/static-pages/handles/fernbergergallery.html" },
    { "source": "/handles/kerlingallery", "destination": "/static-pages/handles/kerlingallery.html" },
    { "source": "/handles/thomasvandykegallery", "destination": "/static-pages/handles/thomasvandykegallery.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index,follow" }
      ]
    }
  ]
}
